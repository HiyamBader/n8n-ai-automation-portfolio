          "value": "models/gemini-3-flash-preview"
        },
        "messages": {
          "values": [
            {
              "content": "=You are an expert Arabic social media content creator.\n\nGenerate ONE Facebook post for the following business.\n\nBusiness Information\n\nBrand Name:\n{{ $json.brand_name }}\n\nBusiness Type:\n{{ $json.business_type }}\n\nTarget Audience:\n{{ $json.target_audience }}\n\nLanguage:\n{{ $json.language }}\n\nTone:\n{{ $json.tone }}\n\nBusiness Context:\n{{ $json.content_context }}\n\nContent Boundaries:\n{{ $json.content_boundaries }}\n\nPost Type:\n{{ $json.post_type }}\n\nPost Direction:\n{{ $json.post_type_description }}\n\nRequirements\n\n- Write naturally as a human.\n- Make the opening sentence attention-grabbing.\n- Keep the post between 80 and 180 words.\n- Provide useful value before promotion.\n- Avoid repeating common clichés.\n- End with a question or call to engagement.\n- Add 3-5 relevant hashtags.\n- Do not use Markdown.\n- Return only the final Facebook post."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [
        672,
        -320
      ],
      "id": "aecf97ba-e615-42a6-a518-6974c37cb976",
      "name": "Generate Social Media Post",
      "credentials": {
        "googlePalmApi": {
          "id": "YTrk6F91XsKxrFqm",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const postTypes = [\n  {\n    key: \"educational_tip\",\n    description: \"Share one useful tip related to the business, its products, services, usage, care, selection, or customer experience.\"\n  },\n  {\n    key: \"storytelling\",\n    description: \"Tell a short engaging story connected to the brand, craft, product, customer experience, or business values.\"\n  },\n  {\n    key: \"product_highlight\",\n    description: \"Highlight one product or service in a helpful, elegant, and non-pushy promotional style.\"\n  },\n  {\n    key: \"common_mistake\",\n    description: \"Explain one common mistake customers make related to choosing, using, maintaining, or understanding the product or service.\"\n  },\n  {\n    key: \"interactive_question\",\n    description: \"Ask an engaging question that encourages followers to share preferences, opinions, memories, or experiences.\"\n  },\n  {\n    key: \"behind_the_scenes\",\n    description: \"Create content about craftsmanship, preparation, process, quality, effort, or work behind the final product or service.\"\n  },\n  {\n    key: \"inspirational\",\n    description: \"Write an emotional or inspiring post connected to the brand values, lifestyle, identity, creativity, or customer goals.\"\n  },\n  {\n    key: \"soft_promotion\",\n    description: \"Write a light promotional post that presents value without sounding aggressive or overly sales-focused.\"\n  },\n  {\n    key: \"seasonal\",\n    description: \"Create content related to the current season, holiday, occasion, weather, or shopping moment when relevant.\"\n  }\n];\n\nconst selected = postTypes[Math.floor(Math.random() * postTypes.length)];\n\nreturn [\n  {\n    json: {\n      ...$json,\n      post_type: selected.key,\n      post_type_description: selected.description\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        -320
      ],
      "id": "918f8884-9499-409d-bc93-5dba8f95ca3d",
