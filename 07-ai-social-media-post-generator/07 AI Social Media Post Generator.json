        },
        "messages": {
          "values": [
            {
              "content": "=You are an expert AI image prompt engineer.\n\nCreate one professional image generation prompt based on the following Facebook post.\n\nFacebook Post:\n{{ $json.content.parts[0].text }}\n\nBusiness Name:\n{{ $('Content Configuration').item.json.brand_name }}\n\nBusiness Type:\n{{ $('Content Configuration').item.json.business_type }}\n\nRequirements:\n- The prompt must be in English.\n- Create a realistic, premium-quality social media image.\n- No text inside the image.\n- Cinematic lighting.\n- High detail.\n- Professional composition.\n- Suitable for Facebook.\n- Match the mood of the post.\n- Focus on the business identity.\n- Return only the image prompt."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
